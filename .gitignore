# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments (FastAPI official docs recommend ignoring these)
.venv/
venv/
ENV/
env/

# Environment secrets (Crucial to prevent uploading API keys)
.env
.env.*
!.env.example

# Testing and coverage
.pytest_cache/
.coverage
htmlcov/

# SQL databases (if using SQLite locally)
*.sqlite3
*.db

# IDE and Editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# OS generated files
.DS_Store
Thumbs.db
